# =============================================================================
# IronRAG ↔ BookStack connector — operator config
#
# Copy to `.env.local` (gitignored), fill values, then run the connector.
# =============================================================================

# --- BookStack ---
# Base URL of your BookStack instance (no trailing slash).
BOOKSTACK_BASE_URL=https://wiki.example.com
# API token pair created in BookStack admin → API tokens. The token user
# must have read access to every shelf/book/page the connector should sync.
BOOKSTACK_TOKEN_ID=your_bookstack_token_id
BOOKSTACK_TOKEN_SECRET=your_bookstack_token_secret
# HMAC-SHA256 secret BookStack signs `/webhook/bookstack` deliveries with
# (BookStack admin → Webhooks). Leave empty to skip webhook signature
# verification — only ADMIN_BEARER_TOKEN will then gate the endpoint.
BOOKSTACK_WEBHOOK_SECRET=
# Optional: BookStack page export format. markdown is the canonical choice.
# Allowed: markdown | html | plaintext | pdf
BOOKSTACK_PAGE_FORMAT=markdown
# Optional: BookStack API rate-limit gate (seconds between requests).
BOOKSTACK_MIN_REQUEST_INTERVAL_SECONDS=0.7
# Optional: BookStack 429/5xx retry tuning.
BOOKSTACK_RETRY_MAX=5
BOOKSTACK_RETRY_BACKOFF_SECONDS=1.5
BOOKSTACK_RETRY_MAX_SLEEP_SECONDS=30
# Optional: shelf reverse-index cache TTL (used only when routing.yaml has
# a `shelf:` match key).
BOOKSTACK_SHELF_CACHE_TTL_SECONDS=900

# --- IronRAG ---
# Base URL of your IronRAG backend.
IRONRAG_BASE_URL=https://ironrag.example.com
# IAM token with POLICY_DOCUMENTS_WRITE on every library this connector can
# target via routing.yaml.
IRONRAG_API_TOKEN=irt_xxxxxxxxxxxx

# --- Routing ---
# Path to YAML mapping source items to (workspace, library) pairs.
# See routing.yaml.example for the canonical schema.
ROUTING_CONFIG_PATH=routing.yaml

# --- Run mode ---
# poll    — only the periodic sweep runs
# webhook — only /webhook/bookstack runs (manual /sync/run still works)
# both    — sweep + webhooks side by side (recommended)
RUN_MODE=both

# --- Sync loop (consulted unless RUN_MODE=webhook) ---
SYNC_INTERVAL_SECONDS=1800
SYNC_RUN_ON_STARTUP=false
SYNC_CONCURRENCY=4

# --- Push policies (per-kind overrides live in routing.yaml) ---
DEFAULT_POLICY_ON_NEW=create
DEFAULT_POLICY_ON_CHANGED=replace
DEFAULT_POLICY_ON_MISSING=delete
DEFAULT_POLICY_ON_DUPLICATE_CONTENT=skip

# --- Persistent state ---
# SQLite cursor so the next sweep ships only the diff. Mount as a volume
# in containerized deployments.
STATE_DB_PATH=/var/lib/ironrag-connector/state.sqlite

# --- HTTP server ---
HOST=0.0.0.0
PORT=8088
LOG_LEVEL=info
# Bearer required on POST /sync/run and POST /webhook/bookstack.
ADMIN_BEARER_TOKEN=change-me
